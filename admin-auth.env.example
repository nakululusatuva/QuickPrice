# Generate real values locally; do not invent or reuse credentials:
#   quickprice admin-credentials --origin https://quickprice.example.com
#
# Install the five emitted assignments in /etc/quickprice/admin-auth.env with
# root:quickprice ownership and mode 0640. Never place the temporary plaintext
# password, an authenticator code, or a session token in this file.
#
# These values bootstrap the mode-0600 managed account file only when it is
# absent. After the first password change, remove the USERNAME, PASSWORD_VERIFIER,
# and PASSWORD_CHANGE_REQUIRED assignments so the temporary password cannot be
# restored by accidentally deleting the managed account file.
#
# QUICKPRICE_ADMIN_USERNAME=admin
# QUICKPRICE_ADMIN_PASSWORD_VERIFIER=scrypt$32768$8$1$...
# QUICKPRICE_ADMIN_PASSWORD_CHANGE_REQUIRED=true
# QUICKPRICE_ADMIN_TOTP_SECRET=BASE32_ENROLLMENT_SECRET
# QUICKPRICE_ADMIN_ORIGIN=https://quickprice.example.com
# QUICKPRICE_ADMIN_TRUSTED_PROXY_IPS=127.0.0.1
