# Generate real values locally; do not invent or reuse credentials:
#   quickprice admin-credentials --origin https://quickprice.example.com
#
# Install the three emitted assignments in /etc/quickprice/admin-auth.env with
# root:quickprice ownership and mode 0640. Never place the raw administrator
# key, an authenticator code, or a session token in this file.
#
# QUICKPRICE_ADMIN_KEY_VERIFIER=scrypt$32768$8$1$...
# QUICKPRICE_ADMIN_TOTP_SECRET=BASE32_ENROLLMENT_SECRET
# QUICKPRICE_ADMIN_ORIGIN=https://quickprice.example.com
# QUICKPRICE_ADMIN_TRUSTED_PROXY_IPS=127.0.0.1
