# Copy this file to provider-keys.env or another protected, untracked path.
# Set QUICKPRICE_PROVIDER_KEYS_FILE to that path for direct application runs.
# The native service reads this file directly through QUICKPRICE_PROVIDER_KEYS_FILE.

# Public Binance and Kraken spot data do not require credentials. Missing
# optional credentials disable the corresponding route.
QUICKPRICE_ALPACA_API_KEY=
QUICKPRICE_ALPACA_API_SECRET=
QUICKPRICE_FINNHUB_API_KEY=
QUICKPRICE_TWELVE_DATA_API_KEY=
QUICKPRICE_ALPHA_VANTAGE_API_KEY=
QUICKPRICE_COINGECKO_API_KEY=
QUICKPRICE_FRED_API_KEY=

# Binance's signed WBETH rate history is the primary WBETH APR source. Use a
# read-only key with trading and withdrawals disabled. Ethereum RPC URLs are
# the second source and may contain credentials; separate URLs with commas.
# RPC destinations are host-managed and cannot be changed through /admin.
QUICKPRICE_ETHEREUM_RPC_URLS=
QUICKPRICE_BINANCE_API_KEY=
QUICKPRICE_BINANCE_API_SECRET=

# BETH market data and staking APR are public. These optional fields reserve a
# write-only location for future authenticated OKX capabilities.
QUICKPRICE_OKX_API_KEY=
QUICKPRICE_OKX_API_SECRET=
QUICKPRICE_OKX_API_PASSPHRASE=
