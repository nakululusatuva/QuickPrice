# Non-secret application configuration. Provider credentials belong in the
# separate provider-keys.env file; never add provider secrets here.

# QuickPrice authentication. Generate a raw key and hash with:
#   quickprice hash-key --generate
# Store only the sha256:<hex> value here. Keep the raw key in Excel or a
# password manager.
QUICKPRICE_API_KEY_HASHES=sha256:replace_with_64_lowercase_hex_characters

# Only explicitly enabled, installed Python entry-point plugins are loaded.
QUICKPRICE_ENABLED_PLUGINS=builtin

# Paper trading is the default clock endpoint for personal/free IEX accounts.
QUICKPRICE_ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets/v2

# Staking yield may use provider credentials from provider-keys.env and then
# estimate trailing yield from the configured market-ratio window.
QUICKPRICE_STAKING_YIELD_MARKET_FALLBACK_DAYS=30

# Native filesystem path. Use a local persistent disk, not NFS, SMB, or a path
# shared concurrently between Windows and WSL.
QUICKPRICE_DATABASE_PATH=/var/lib/quickprice/quickprice.sqlite3

# Production safety and request controls.
QUICKPRICE_PRODUCTION=true
QUICKPRICE_REQUIRE_FREE_THREADED=true
QUICKPRICE_BACKGROUND_ENABLED=true
QUICKPRICE_RATE_LIMIT_ENABLED=true
QUICKPRICE_REQUESTS_PER_MINUTE=120
QUICKPRICE_REQUEST_BURST=20
QUICKPRICE_INVALID_REQUESTS_PER_MINUTE=30
QUICKPRICE_INVALID_REQUEST_BURST=10

# Provider routing and circuit breaking.
QUICKPRICE_PROVIDER_TIMEOUT_SECONDS=8
QUICKPRICE_CIRCUIT_FAILURE_THRESHOLD=3
QUICKPRICE_CIRCUIT_OPEN_SECONDS=60

# Hard free-tier budgets and collection cadence.
QUICKPRICE_TWELVE_DAILY_CREDITS=790
QUICKPRICE_TWELVE_FX_RESERVE_CREDITS=769
QUICKPRICE_ALPHA_VANTAGE_DAILY_CREDITS=25
QUICKPRICE_COINGECKO_MONTHLY_CREDITS=9000
# CNH is the fast USD hub spoke. The USD_HKD compatibility name controls the
# shared EUR, GBP, HKD, and SGD hub-spoke cadence.
QUICKPRICE_USD_CNH_POLL_SECONDS=240
QUICKPRICE_USD_HKD_POLL_SECONDS=900
QUICKPRICE_CRYPTO_POLL_SECONDS=1
QUICKPRICE_EQUITY_POLL_SECONDS=5
QUICKPRICE_METADATA_POLL_SECONDS=21600
QUICKPRICE_HISTORY_POLL_SECONDS=3600
QUICKPRICE_HIGH_FREQUENCY_PUBLISH_MS=250

# SQLite writer batching.
QUICKPRICE_SQLITE_BATCH_SIZE=100
QUICKPRICE_SQLITE_BATCH_MS=250

# The public proxy is separate. QuickPrice must remain loopback-only on a
# production host even if the command-line service arguments are changed.
QUICKPRICE_HOST=127.0.0.1
QUICKPRICE_PORT=8080
QUICKPRICE_LOG_LEVEL=info

# Native CPython source build parallelism.
QUICKPRICE_BUILD_JOBS=2
