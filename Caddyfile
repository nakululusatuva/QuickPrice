{
	admin off
	email {$ACME_EMAIL}
	servers {
		protocols h1 h2
		max_header_size 16KB
		timeouts {
			read_header 5s
			read_body 10s
			write 30s
			idle 2m
		}
	}
}

{$QUICKPRICE_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
		-Server
	}

	reverse_proxy 127.0.0.1:8080 {
		health_uri /health/live
		health_interval 30s
		health_timeout 3s
	}

	log {
		output {$QUICKPRICE_CADDY_ACCESS_LOG_OUTPUT:stdout}
		format filter {
			request>headers>X-Api-Key delete
			request>uri query {
				delete api_key
				delete apikey
				delete key
			}
			wrap json
		}
	}
}
